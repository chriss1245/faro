---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not found" description="This page drifted off the map.">
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="eyebrow mb-4">// 404</p>
    <h1 class="text-5xl font-semibold text-fog-100">Lost at sea.</h1>
    <p class="mt-4 text-fog-300">
      This page drifted off the map — but the beacon's still on.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full bg-beacon px-5 py-2.5 text-sm font-semibold text-ink-950 transition-colors hover:bg-beacon-600"
    >
      Back home
    </a>
  </section>
</Layout>
