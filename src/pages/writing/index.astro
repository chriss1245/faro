---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Layout title="Writing" description="Stories from building data products in public.">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <p class="eyebrow mb-2">// writing</p>
    <h1 class="text-3xl font-semibold text-fog-100 sm:text-4xl">Building, out loud.</h1>
    <p class="mt-3 max-w-xl text-fog-300">
      Notes and stories from designing, breaking and shipping the things in my portfolio.
    </p>

    <div class="mt-12 divide-y divide-line/70">
      {
        posts.length === 0 && (
          <p class="text-fog-400">No posts yet — the first one is on its way.</p>
        )
      }
      {
        posts.map((post) => (
          <a href={`/writing/${post.id}`} class="group flex flex-col gap-1 py-6">
            <span class="font-mono text-xs text-fog-400">{fmt(post.data.date)}</span>
            <h2 class="text-xl font-medium text-fog-100 transition-colors group-hover:text-beacon">
              {post.data.title}
            </h2>
            <p class="text-sm text-fog-400">{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
