---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";

// TODO: replace placeholder content with your real CV.
const experience = [
  {
    role: "Data Scientist",
    org: "TODO — Company",
    period: "2023 — Present",
    points: [
      "TODO: a result you're proud of, with a number.",
      "TODO: a system or model you built and shipped.",
    ],
  },
];
const education = [
  { title: "TODO — Degree", org: "TODO — University", period: "20XX" },
];
const skills = [
  "Python", "SQL", "Pandas", "scikit-learn", "PyTorch",
  "LLMs / RAG", "Postgres", "Docker", "Astro",
];
---

<Layout title="CV" description={`${site.name} — curriculum vitae`}>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="eyebrow mb-2">// curriculum vitae</p>
        <h1 class="text-3xl font-semibold text-fog-100 sm:text-4xl">{site.name}</h1>
        <p class="mt-2 text-fog-300">{site.role} · {site.location}</p>
      </div>
      {
        site.cvPdf && (
          <a
            href={site.cvPdf}
            class="rounded-full border border-line bg-ink-800 px-4 py-2 text-sm text-fog-100 transition-colors hover:border-beacon/50 hover:text-beacon"
          >
            Download PDF
          </a>
        )
      }
    </div>

    <div class="mt-12 space-y-12">
      <div>
        <h2 class="mb-5 font-mono text-sm uppercase tracking-widest text-beacon">Experience</h2>
        <div class="space-y-8">
          {
            experience.map((job) => (
              <div class="border-l border-line pl-5">
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <h3 class="text-lg font-medium text-fog-100">
                    {job.role} · <span class="text-fog-300">{job.org}</span>
                  </h3>
                  <span class="font-mono text-xs text-fog-400">{job.period}</span>
                </div>
                <ul class="mt-3 space-y-1.5 text-sm leading-relaxed text-fog-300">
                  {job.points.map((p) => (
                    <li class="flex gap-2">
                      <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-beacon" />
                      {p}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h2 class="mb-5 font-mono text-sm uppercase tracking-widest text-beacon">Education</h2>
        <div class="space-y-4">
          {
            education.map((e) => (
              <div class="flex flex-wrap items-baseline justify-between gap-2 border-l border-line pl-5">
                <h3 class="font-medium text-fog-100">
                  {e.title} · <span class="text-fog-300">{e.org}</span>
                </h3>
                <span class="font-mono text-xs text-fog-400">{e.period}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h2 class="mb-5 font-mono text-sm uppercase tracking-widest text-beacon">Skills</h2>
        <div class="flex flex-wrap gap-2">
          {
            skills.map((s) => (
              <span class="rounded-md border border-line bg-ink-850/60 px-3 py-1 font-mono text-xs text-fog-200">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
